# ── Database ───────────────────────────────────────────────────
# Leave DATABASE_URL unset to use local SQLite (dev).
# Set it to your CockroachDB (or any Postgres) connection string for production.
#
# DATABASE_URL=postgresql://user:pass@host:26257/dbname?sslmode=verify-full

# SQLite database path (used only when DATABASE_URL is unset)
DB_PATH=./mfapi.db

# API server
PORT=3001

# Rate limiting (per client IP, in-memory). Defaults: 2500 requests / 1 minute.
RATE_LIMIT_MAX=2500
RATE_LIMIT_WINDOW=1 minute

# Pipeline tuning (seed.js)
CONCURRENCY=8          # simultaneous mfapi.in requests (stay ≤ 15 to avoid rate-limit)
NAV_YEARS=5            # years of NAV history to seed (default 5)
MFAPI_BASE=https://api.mfapi.in

# NAV sync endpoint — set this to protect POST /sync-nav from unauthorized calls.
# Use the same value as the SYNC_NAV_SECRET GitHub Actions secret.
# Leave unset to disable auth (not recommended in production).
# SYNC_NAV_SECRET=your-secret-here

# Axiom analytics (optional — leave unset in local dev, set in Vercel for prod).
# AXIOM_TOKEN=xaat-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AXIOM_DATASET=market-data-api
