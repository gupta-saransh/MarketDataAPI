# Base URL the explorer uses for API calls.
# Default is `/api` (same origin) — works in dev (via Vite proxy) and in
# production on Vercel (where /api/* is routed to the serverless API).
#
# Only set this if your API is hosted on a DIFFERENT origin, e.g.:
# VITE_API_URL=https://my-market-data-api.onrender.com
VITE_API_URL=/api

# (dev only) where the Vite proxy forwards /api during `npm run dev`
VITE_DEV_API_TARGET=http://localhost:3001
