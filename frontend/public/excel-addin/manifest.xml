<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">

  <Id>a4f2e8d1-c3b5-4720-9e6a-b7d4f9c13082</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Market Data API</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Market Data API" />
  <Description DefaultValue="Indian mutual fund NAV data as Excel functions" />
  <IconUrl DefaultValue="https://market-data-api-psi.vercel.app/favicon.ico" />
  <HighResolutionIconUrl DefaultValue="https://market-data-api-psi.vercel.app/favicon.ico" />
  <SupportUrl DefaultValue="https://market-data-api-psi.vercel.app" />

  <AppDomains>
    <AppDomain>https://market-data-api-psi.vercel.app</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Workbook" />
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="CustomFunctionsRuntime" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://market-data-api-psi.vercel.app/excel-addin/functions.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.1">
          <bt:Set Name="CustomFunctionsRuntime" MinVersion="1.1" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="Workbook">
          <AllFormContexts />
          <ExtensionPoints>
            <ExtensionPoint xsi:type="CustomFunctions">
              <Script>
                <bt:Url DefaultValue="https://market-data-api-psi.vercel.app/excel-addin/functions.js" />
              </Script>
              <Page>
                <bt:Url DefaultValue="https://market-data-api-psi.vercel.app/excel-addin/functions.html" />
              </Page>
              <Metadata>
                <bt:Url DefaultValue="https://market-data-api-psi.vercel.app/excel-addin/functions.json" />
              </Metadata>
              <Namespace DefaultValue="MF" />
            </ExtensionPoint>
          </ExtensionPoints>
        </Host>
      </Hosts>

      <Resources>
        <bt:Urls>
          <bt:Url id="Functions.Script.Url"   DefaultValue="https://market-data-api-psi.vercel.app/excel-addin/functions.js" />
          <bt:Url id="Functions.Page.Url"     DefaultValue="https://market-data-api-psi.vercel.app/excel-addin/functions.html" />
          <bt:Url id="Functions.Metadata.Url" DefaultValue="https://market-data-api-psi.vercel.app/excel-addin/functions.json" />
        </bt:Urls>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
